<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>The Spooky Bookshelf - {{ title }}</title>
        <link href="/assets/css/style.css" rel="stylesheet">
        <script src="https://kit.fontawesome.com/aaa188427f.js" crossorigin="anonymous"></script>
    </head>
    <body>
        <header>
            <img src="/assets/images/tsbheader.png">
        </header>
        <div class="wrapper">
           <aside class="left-bar">
            <h3 class="widget-top">Switch Fonts</h3>
            Make the font more readable<br><br>
            <button id="font-toggle" onclick="forceFontToggle()">Switch Font</button>
            <h3 class="widget-top">Menu</h3>
            <div class="menu">
                <ul>
                    <li><a href="../index.html">Home</a></li>
                    <li><a href="../about.html">About</a></li>
                    <li><a href="../reviews.html">Book Reviews</a></li>
                    <!-- <li><a href="../crafts.html">Crafty Things</a></li>
                    <li><a href="../fun.html">Fun Things </a></li> -->
                    <li><a href="../policies.html">Site Policies</a></li>
                </ul>
            </div>
            <h3 class="widget-top">Updates</h3>
                <textarea class="updates" cols="20" rows="5">03/08/2026 - Added a couple reviews, removed a bunch of reviews, switched some links, removed chatbox because no one used it.</textarea>
                <h3>Stamps</h3>
            <img src="../assets/blinkies/animalcrossingstamp.png" alt="Animal Crossing Stamp">
            <img src="../assets/blinkies/ilovemusicstamp.gif" alt="I Love Music Stamp">
           </aside>
           <main class="main">
           {{ content | safe }}
           </main>
           <aside class="right-bar">
            <h3 class="widget-top">Current Mood</h3>
            <a href="https://www.imood.com/users/thespookybookshelf"><img src="https://moods.imood.com/display/uname-thespookybookshelf/fg-ffffff/bg-000000/imood.gif" alt="The current mood of thespookybookshelf at www.imood.com"></a>
            <h3 class="widget-top">Guestbook</h3>
            <a href="http://users3.smartgb.com/g/g.php?a=s&i=g36-40123-0a" target="_blank">Sign Here Please!</a>
            <h3 class="widget-top">Hits/Visits</h3>
            <script type="text/javascript" src="https://counter.websiteout.com/js/35/0/0/0"></script>
            <h3 class="widget-top">Pokémon</h3>
            <a href="https://pkmn.aquarel.nu" rel="noopener noreferrer" style="border: 0px none; background: transparent;" title="I Choose You! | PokemonName"><img src="../assets/fanlistings/Oddish.png" style="margin: auto -10px;"></a>
           </aside>
        </div>
        <div class="footer">
            &copy; {{ currentYear.year }} Charity Gamble <a href="https://neocities.org/site/thespookybookshelf" target="_blank">neocities profile</a> | <a href="https://11ty.dev" target="_blank">11ty</a> | <a href="https://github.com/charitygamble/spookybookshelf" target="_blank">github</a> | <a href="https://neocities.org" target="_blank">neocities</a> 
        </div>
<script src="../assets/scripts/font.js" defer></script>
    </body>
</html>